{
  "rules": [
    { "if": { "keywords": ["ls", "grep", "cat", "echo", "pwd", "which", "cd", "find", "touch", "mkdir"] }, "then": "light" },
    { "if": { "keywords": ["architecture", "design system", "strategic", "review all", "deep dive", "compare options", "tradeoffs", "research", "think"] }, "then": "heavy" },
    { "if": { "tokenCount": { "gt": 8000 } }, "then": "heavy" }
  ],
  "defaultModel": "claude-sonnet-4-6",
  "models": {
    "light": "claude-haiku-4-5",
    "medium": "claude-sonnet-4-6",
    "heavy": "claude-opus-4-8"
  }
}
